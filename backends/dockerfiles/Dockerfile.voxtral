# syntax=docker/dockerfile:1.7
# -----------------------------------------------------------------------------
# oCabra backend: Voxtral (vllm-omni multimodal audio)
# -----------------------------------------------------------------------------
# Resulting image   : ghcr.io/ocabra/backend-voxtral:latest-cuda12
# Estimated size    : ~10 GB (vllm + vllm-omni + torch)
# Variants          : cuda12 (default)
# Key deps          : vllm>=0.18.0, vllm-omni>=0.18.0, fastapi, uvicorn, httpx,
#                     soundfile, numpy
# Runtime entry     : /backend/venv/bin/python /backend/workers/voxtral_worker.py
# -----------------------------------------------------------------------------

ARG BASE_IMAGE=nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04
ARG VLLM_OMNI_VERSION=0.18.0

FROM ${BASE_IMAGE} AS builder

ARG VLLM_OMNI_VERSION

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        software-properties-common \
        gnupg \
        curl \
        ffmpeg \
        libsndfile1 \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
        python3.11 \
        python3.11-venv \
        python3.11-dev \
    && rm -rf /var/lib/apt/lists/*

RUN python3.11 -m venv /backend/venv \
    && /backend/venv/bin/pip install --upgrade pip setuptools wheel

RUN /backend/venv/bin/pip install \
        "vllm>=0.18.0" \
        "vllm-omni>=${VLLM_OMNI_VERSION}" \
        "soundfile>=0.12" \
        "numpy" \
        "fastapi>=0.115" \
        "uvicorn[standard]>=0.32" \
        "httpx>=0.28" \
        "pydantic>=2.10"

RUN mkdir -p /backend/workers /backend/bin
RUN cp /usr/bin/ffmpeg /backend/bin/ffmpeg || true

COPY backend/workers/voxtral_worker.py /backend/workers/voxtral_worker.py

RUN echo "{\"backend_type\": \"voxtral\", \"python_bin\": \"/backend/venv/bin/python\", \"worker\": \"/backend/workers/voxtral_worker.py\"}" \
        > /backend/metadata.template.json

FROM scratch

LABEL org.opencontainers.image.source="https://github.com/ocabra/ocabra" \
      org.opencontainers.image.title="ocabra-backend-voxtral" \
      org.opencontainers.image.description="Voxtral (vllm-omni) audio multimodal backend for oCabra" \
      org.opencontainers.image.licenses="Apache-2.0"

COPY --from=builder /backend /backend
