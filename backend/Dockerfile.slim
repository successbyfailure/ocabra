# oCabra — slim API image (Bloque 15 Fase 4)
#
# Contains ONLY the core oCabra runtime: FastAPI, SQLAlchemy, Pydantic,
# scheduling, stats. No AI backends pre-installed.
#
# Backends are installed at runtime via BackendInstaller:
#   - method=source  -> pip install into /data/backends/<name>/venv/
#   - method=oci     -> docker pull + extract (Fase 3, not yet wired)
#
# System-level deps that several backends share (ffmpeg, libsndfile1, sox) are
# kept in this base image so audio/tts/stt backends don't have to reinstall
# them per venv.
#
# CUDA runtime libs are NOT in this image. Backends that need CUDA pull them
# as part of their torch wheel (from https://download.pytorch.org/whl/cu124
# or equivalent). The NVIDIA container toolkit provides the driver at
# runtime via /dev/nvidia* + libcuda.so.1.

FROM docker:28-cli AS docker-cli

# The compose plugin is shipped separately from the docker CLI in the
# upstream docker/compose project. service_manager runs `docker compose
# up -d <service>` from inside the api container to start optional
# external services (ComfyUI, ACE-Step, Hunyuan3D, A1111), so we need
# the plugin on the same docker CLI install. Pinned for reproducibility.
FROM curlimages/curl:8.10.0 AS compose-plugin
ARG DOCKER_COMPOSE_VERSION=v2.31.0
RUN curl -fsSL \
        "https://github.com/docker/compose/releases/download/${DOCKER_COMPOSE_VERSION}/docker-compose-linux-x86_64" \
        -o /tmp/docker-compose

FROM python:3.11-slim-bookworm AS base

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    BACKENDS_FAT_IMAGE=false

# Audio/video system deps (shared by whisper, tts, diffusers-image2audio,
# chatterbox, voxtral). Keeping them in the base image avoids re-installing
# apt packages from inside BackendInstaller venvs.
#
# Build toolchain (gcc, g++, cmake, ninja-build, git, build-essential) ships
# in the base image because most modern Python LLM stacks JIT-compile
# CUDA/C++ kernels at runtime (Triton in vllm/voxtral, tvm_ffi in sglang)
# and the native backends (llama_cpp, bitnet, acestep) cmake-build their
# binaries during ``BackendInstaller.install()``. Adds ~250 MB to the slim
# image — still ~50× smaller than the fat. Specs may still declare these
# in ``apt_packages`` for OCI-image clarity; the runtime ``apt-get install``
# becomes a fast no-op when the deps are already present.
#
# curl is kept for the /health probe used by docker compose healthcheck.
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        cmake \
        curl \
        ffmpeg \
        g++ \
        gcc \
        git \
        libsndfile1 \
        libsox3 \
        ninja-build \
        sox \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=docker-cli /usr/local/bin/docker /usr/bin/docker
# Install the compose plugin under the system-wide cli-plugins dir so any
# user inside the container picks it up via `docker compose`.
COPY --from=compose-plugin /tmp/docker-compose /usr/libexec/docker/cli-plugins/docker-compose
RUN chmod +x /usr/libexec/docker/cli-plugins/docker-compose

# Install only the core oCabra runtime (no backends, no venvs). Dev extras
# (pytest/ruff) go in the dev stage below.
COPY pyproject.toml .
RUN pip install --upgrade pip setuptools wheel \
    && pip install -e "."

# --- dev target (slim + pytest/ruff, no AI backends) ---
FROM base AS dev
RUN pip install -e ".[dev]"
COPY . .
RUN chmod +x /app/docker-entrypoint.sh

# --- production target ---
FROM base AS production
COPY . .
RUN chmod +x /app/docker-entrypoint.sh

EXPOSE 8000
ENTRYPOINT ["/app/docker-entrypoint.sh"]
CMD ["uvicorn", "ocabra.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
