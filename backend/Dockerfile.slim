# oCabra — slim API image (Bloque 15 Fase 4)
#
# Contains ONLY the core oCabra runtime: FastAPI, SQLAlchemy, Pydantic,
# scheduling, stats. No AI backends pre-installed.
#
# Backends are installed at runtime via BackendInstaller:
#   - method=source  -> pip install into /data/backends/<name>/venv/
#   - method=oci     -> docker pull + extract (Fase 3, not yet wired)
#
# System-level deps that several backends share (ffmpeg, libsndfile1, sox) are
# kept in this base image so audio/tts/stt backends don't have to reinstall
# them per venv.
#
# CUDA runtime libs are NOT in this image. Backends that need CUDA pull them
# as part of their torch wheel (from https://download.pytorch.org/whl/cu124
# or equivalent). The NVIDIA container toolkit provides the driver at
# runtime via /dev/nvidia* + libcuda.so.1.

FROM docker:28-cli AS docker-cli

FROM python:3.11-slim-bookworm AS base

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Audio/video system deps (shared by whisper, tts, diffusers-image2audio,
# chatterbox, voxtral). Keeping them in the base image avoids re-installing
# apt packages from inside BackendInstaller venvs.
#
# curl is kept for the /health probe used by docker compose healthcheck.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        ffmpeg \
        libsndfile1 \
        libsox3 \
        sox \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=docker-cli /usr/local/bin/docker /usr/bin/docker

# Install only the core oCabra runtime (no backends, no venvs). Dev extras
# (pytest/ruff) go in the dev stage below.
COPY pyproject.toml .
RUN pip install --upgrade pip setuptools wheel \
    && pip install -e "."

# --- dev target (slim + pytest/ruff, no AI backends) ---
FROM base AS dev
RUN pip install -e ".[dev]"
COPY . .
RUN chmod +x /app/docker-entrypoint.sh

# --- production target ---
FROM base AS production
COPY . .
RUN chmod +x /app/docker-entrypoint.sh

EXPOSE 8000
ENTRYPOINT ["/app/docker-entrypoint.sh"]
CMD ["uvicorn", "ocabra.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
