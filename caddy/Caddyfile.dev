{
    admin off
}

:80 {
    # API routes → backend
    handle /v1/* {
        reverse_proxy api:8000
    }
    handle /api/* {
        reverse_proxy api:8000
    }
    handle /ocabra/* {
        reverse_proxy api:8000
    }
    handle /health {
        reverse_proxy api:8000
    }
    handle /ready {
        reverse_proxy api:8000
    }
    handle /docs {
        reverse_proxy api:8000
    }
    handle /redoc {
        reverse_proxy api:8000
    }
    handle /openapi.json {
        reverse_proxy api:8000
    }
    handle /metrics {
        reverse_proxy api:8000
    }

    # Frontend (Vite dev server) — everything else
    handle {
        reverse_proxy frontend:5173
    }
}

:{$SERVICES_PORTAL_INTERNAL_PORT:81} {
    root * /srv/services

    handle /health {
        header Content-Type application/json
        respond `{"status":"ok","service":"mks-generation-services"}` 200
    }

    handle / {
        try_files /index.html
        file_server
    }

    handle_path {$COMFYUI_UI_BASE_PATH:/comfy}/ws/* {
        rewrite * /ocabra/services/comfyui/ws/{path}
        reverse_proxy api:8000
    }

    handle {$COMFYUI_UI_BASE_PATH:/comfy}/ws {
        rewrite * /ocabra/services/comfyui/ws
        reverse_proxy api:8000
    }

    handle_path {$HUNYUAN_UI_BASE_PATH:/hunyuan}/* {
        rewrite * /ocabra/services/hunyuan/proxy/{path}
        reverse_proxy api:8000
    }

    handle {$HUNYUAN_UI_BASE_PATH:/hunyuan} {
        rewrite * /ocabra/services/hunyuan/proxy
        reverse_proxy api:8000
    }

    handle_path {$COMFYUI_UI_BASE_PATH:/comfy}/* {
        rewrite * /ocabra/services/comfyui/proxy/{path}
        reverse_proxy api:8000
    }

    handle {$COMFYUI_UI_BASE_PATH:/comfy} {
        rewrite * /ocabra/services/comfyui/proxy
        reverse_proxy api:8000
    }

    handle_path {$A1111_UI_BASE_PATH:/a1111}/* {
        rewrite * /ocabra/services/a1111/proxy/{path}
        reverse_proxy api:8000 {
            header_up X-Forwarded-Uri {http.request.uri}
        }
    }

    handle {$A1111_UI_BASE_PATH:/a1111} {
        rewrite * /ocabra/services/a1111/proxy
        reverse_proxy api:8000
    }

    handle {
        try_files {path} /index.html
        file_server
    }
}
