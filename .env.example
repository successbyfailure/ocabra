# =============================================================
# oCabra — Environment Variables
# Copia este fichero como .env y rellena los valores
# =============================================================

# --- Base de datos ---
POSTGRES_USER=ocabra
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ocabra
DATABASE_URL=postgresql+asyncpg://ocabra:change_me_in_production@postgres:5432/ocabra

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Modelos ---
# Carpeta raíz donde se almacenan los modelos descargados
MODELS_DIR=./data/models
# Carpeta de caché de HuggingFace
HF_CACHE_DIR=./data/hf_cache
# Token de HuggingFace (opcional, necesario para modelos gated/privados)
HF_TOKEN=

# --- GPUs ---
# GPU preferida por defecto: 0=RTX 3060 (12GB), 1=RTX 3090 (24GB)
DEFAULT_GPU_INDEX=1
# Rango de puertos para workers de modelos
WORKER_PORT_RANGE_START=18000
WORKER_PORT_RANGE_END=19000
# Buffer de VRAM a reservar siempre libre (MB)
VRAM_BUFFER_MB=512
# Umbral de VRAM usada (%) que dispara evicción automática
VRAM_PRESSURE_THRESHOLD_PCT=90

# --- Evicción de modelos ---
# Tiempo de inactividad antes de descargar modelos on_demand (segundos)
IDLE_TIMEOUT_SECONDS=300

# --- LiteLLM ---
LITELLM_BASE_URL=http://litellm:4000
LITELLM_ADMIN_KEY=
# Sincronizar modelos automáticamente con LiteLLM al cargar/descargar
LITELLM_AUTO_SYNC=false

# --- Energía ---
# Coste de la electricidad en €/kWh (para estimación de costes)
ENERGY_COST_EUR_KWH=0.15

# --- Servidor ---
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
# Versión de la aplicación
APP_VERSION=0.1.0
