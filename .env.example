# =============================================================
# oCabra — Environment Variables
# Copia este fichero como .env y rellena los valores
# =============================================================

# --- Base de datos ---
POSTGRES_USER=ocabra
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ocabra
DATABASE_URL=postgresql+asyncpg://ocabra:change_me_in_production@postgres:5432/ocabra

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Modelos ---
# Carpeta raíz donde se almacenan los modelos descargados
MODELS_DIR=./data/models
# Carpeta de caché de HuggingFace
HF_CACHE_DIR=./data/hf_cache
# Raíz compartida externa de modelos/artefactos IA en el host
AI_MODELS_ROOT=/docker/ai-models
# Token de HuggingFace (opcional, necesario para modelos gated/privados)
HF_TOKEN=
# URL interna del servicio Ollama (en docker-compose: http://ollama:11434)
OLLAMA_BASE_URL=http://ollama:11434
# Tiempo de keep-alive al cargar modelos Ollama (ej: 30m, 1h, 0 para descargar)
OLLAMA_KEEP_ALIVE=30m
# Intervalo de sincronizacion del inventario/runtime de Ollama (segundos)
OLLAMA_INVENTORY_SYNC_INTERVAL_SECONDS=15

# --- GPUs ---
# GPU preferida por defecto: 0=RTX 3060 (12GB), 1=RTX 3090 (24GB)
DEFAULT_GPU_INDEX=1
# Rango de puertos para workers de modelos
WORKER_PORT_RANGE_START=18000
WORKER_PORT_RANGE_END=19000
# Porción de VRAM total que vLLM intenta reservar (0.0 - 1.0)
VLLM_GPU_MEMORY_UTILIZATION=0.85
# Forzar orden PCI para alinear índices CUDA con NVML (recomendado con GPUs distintas)
CUDA_DEVICE_ORDER=PCI_BUS_ID
# Arranque estable de vLLM; recomendado en GPUs consumidoras mixtas
VLLM_ENFORCE_EAGER=true
# Backend de atención para vLLM (vacío para autodetección, recomendado en Docker dind)
VLLM_ATTENTION_BACKEND=
# Reutiliza KV cache cuando varias peticiones comparten prefijos
VLLM_ENABLE_PREFIX_CACHING=true
# Número máximo de secuencias concurrentes por iteración
VLLM_MAX_NUM_SEQS=16
# Presupuesto total de tokens batched por iteración
VLLM_MAX_NUM_BATCHED_TOKENS=8192
# Tensor parallel por defecto; vacío para autodetección según scheduler
VLLM_TENSOR_PARALLEL_SIZE=
# Limite de contexto efectivo; vacío para usar el del modelo
VLLM_MAX_MODEL_LEN=
# Implementacion de modelo (`auto`, `vllm`, `transformers`); vacio para heuristica de vLLM
VLLM_MODEL_IMPL=
# Runner por defecto (`generate`, `pooling`); vacio para autodeteccion
VLLM_RUNNER=
# Overrides HF en JSON para casos especiales de compatibilidad (ej: {"architectures":["LlamaForCausalLM"]})
VLLM_HF_OVERRIDES=
# Ruta a un chat template alternativo o template inline
VLLM_CHAT_TEMPLATE=
# Formato de contenido del chat template (`string`, `openai`, etc.); vacio para auto
VLLM_CHAT_TEMPLATE_CONTENT_FORMAT=
# Fuente de generation config (`auto`, `vllm`, ruta, etc.); vacio para default de vLLM
VLLM_GENERATION_CONFIG=
# Overrides JSON de generation config para serving
VLLM_OVERRIDE_GENERATION_CONFIG=
# Parser de tool calling para modelos que lo requieran (ej: `hermes`, `qwen3_json`)
VLLM_TOOL_CALL_PARSER=
# Plugin adicional del parser de tools; vacio si no aplica
VLLM_TOOL_PARSER_PLUGIN=
# Parser de reasoning para familias compatibles (ej: `deepseek_r1`, `qwen3`)
VLLM_REASONING_PARSER=
# Correr modelos multimodales solo con la parte de lenguaje para ahorrar VRAM
VLLM_LANGUAGE_MODEL_ONLY=
# Fuerza chunked prefill; vacío para dejar que vLLM decida
VLLM_ENABLE_CHUNKED_PREFILL=
# Swap space por GPU en GiB; vacío para default de vLLM
VLLM_SWAP_SPACE=
# Tipo de KV cache cuantizado; vacío para máxima compatibilidad
VLLM_KV_CACHE_DTYPE=
# Permite cargar repos HF con tokenizers/modelos custom
VLLM_TRUST_REMOTE_CODE=false
# Desactiva logs por petición en vLLM (menos overhead y menos ruido en logs)
VLLM_DISABLE_LOG_REQUESTS=true
# Ruta del binario `llama-server` de llama.cpp
LLAMA_CPP_SERVER_BIN=/usr/local/bin/llama-server
# Capas offloaded a GPU (0 = CPU-only)
LLAMA_CPP_GPU_LAYERS=0
# Contexto por defecto de llama.cpp
LLAMA_CPP_CTX_SIZE=4096
# Threads CPU (vacío = auto)
LLAMA_CPP_THREADS=
# Batch y micro-batch del runtime
LLAMA_CPP_BATCH_SIZE=512
LLAMA_CPP_UBATCH_SIZE=128
# Flags opcionales de llama.cpp
LLAMA_CPP_FLASH_ATTN=false
LLAMA_CPP_MLOCK=true
# Habilita endpoint /v1/embeddings si el modelo lo soporta
LLAMA_CPP_EMBEDDINGS=false
# Timeout de arranque del worker llama.cpp (segundos)
LLAMA_CPP_STARTUP_TIMEOUT_S=30
# Binario Python para ejecutar SGLang (recomendado venv dedicado)
SGLANG_PYTHON_BIN=/opt/sglang-venv/bin/python
# Módulo Python usado para lanzar SGLang
SGLANG_SERVER_MODULE=sglang.launch_server
# Tensor parallel por defecto para SGLang; vacío = número de GPUs asignadas
SGLANG_TENSOR_PARALLEL_SIZE=
# Contexto máximo; vacío = default del modelo/runtime
SGLANG_CONTEXT_LENGTH=
# Fracción de memoria estática para KV cache
SGLANG_MEM_FRACTION_STATIC=0.9
# Permite repos HF con código remoto
SGLANG_TRUST_REMOTE_CODE=false
# Desactiva radix cache si un modelo/runtime da problemas
SGLANG_DISABLE_RADIX_CACHE=false
# Timeout de arranque del worker SGLang (segundos)
SGLANG_STARTUP_TIMEOUT_S=120
# Activa backend TensorRT-LLM (opcional)
TENSORRT_LLM_ENABLED=false
# Modo de lanzamiento del runtime (`binary` = trtllm-serve local, `module` = python -m, `docker` = contenedor NVIDIA)
TENSORRT_LLM_LAUNCH_MODE=binary
# Python launcher para modo `module`
TENSORRT_LLM_PYTHON_BIN=/usr/bin/python3
# Módulo Python para servir TensorRT-LLM en modo `module`
TENSORRT_LLM_SERVE_MODULE=tensorrt_llm.commands.serve
# Binario docker para lanzar modo `docker`
TENSORRT_LLM_DOCKER_BIN=/usr/bin/docker
# Imagen con `trtllm-serve` para modo `docker`
TENSORRT_LLM_DOCKER_IMAGE=nvcr.io/nvidia/tensorrt-llm/release:latest
# Imagen helper local para inspeccionar/matar procesos TRT-LLM huérfanos en host namespace
TENSORRT_LLM_HOST_HELPER_IMAGE=ocabra-api
# Mount host->container para exponer modelos a la imagen TRT-LLM
TENSORRT_LLM_DOCKER_MODELS_MOUNT_HOST=/docker/ai-models/ocabra/models
TENSORRT_LLM_DOCKER_MODELS_MOUNT_CONTAINER=/data/models
# Mount opcional de caché HF para evitar redescargas en arranque
TENSORRT_LLM_DOCKER_HF_CACHE_MOUNT_HOST=/docker/ai-models/ocabra/hf_cache
TENSORRT_LLM_DOCKER_HF_CACHE_MOUNT_CONTAINER=/data/hf_cache
# Ruta del binario `trtllm-serve`
TENSORRT_LLM_SERVE_BIN=/usr/local/bin/trtllm-serve
# Raíz opcional donde viven engines TensorRT-LLM por modelo
TENSORRT_LLM_ENGINES_DIR=
# Backend a usar al servir (`trt`, `pytorch`)
TENSORRT_LLM_BACKEND=trt
# Tokenizer por defecto si no viene en extra_config o junto al engine
TENSORRT_LLM_TOKENIZER_PATH=
# Batch size máximo opcional del servidor
TENSORRT_LLM_MAX_BATCH_SIZE=
# Contexto máximo opcional
TENSORRT_LLM_CONTEXT_LENGTH=
# Permite tokenizers/modelos HF con código remoto
TENSORRT_LLM_TRUST_REMOTE_CODE=false
# Timeout de arranque del worker TensorRT-LLM (segundos)
TENSORRT_LLM_STARTUP_TIMEOUT_S=120
# Ruta del binario `llama-server` compilado desde bitnet.cpp
BITNET_SERVER_BIN=/usr/local/bin/bitnet-server
# Capas offloaded a GPU (0 = CPU-only; recomendado para no ocupar VRAM de vLLM)
BITNET_GPU_LAYERS=0
# Contexto de BitNet
BITNET_CTX_SIZE=4096
# Threads CPU para BitNet (vacío = auto/nproc)
BITNET_THREADS=
# Batch size y micro-batch size de inferencia
BITNET_BATCH_SIZE=512
BITNET_UBATCH_SIZE=128
# Número de slots en paralelo
BITNET_PARALLEL=1
# Flags opcionales de runtime
BITNET_FLASH_ATTN=false
BITNET_MLOCK=true
# Timeout de arranque del worker BitNet (segundos)
BITNET_STARTUP_TIMEOUT_S=30
# Build args (docker-compose -> backend/Dockerfile)
BITNET_COMMIT=main
BITNET_PRETUNED_MODEL=bitnet_b1_58-3B
BITNET_KERNEL_FLAVOR=tl2
BITNET_BUILD_JOBS=8
BITNET_ENABLE_CUDA=false
# Dtype de ejecución en worker Diffusers (`auto`, `float16`, `bfloat16`, `float32`)
DIFFUSERS_TORCH_DTYPE=auto
# Activa `torch.compile` en Diffusers (mejora throughput tras warmup, mayor tiempo de arranque)
DIFFUSERS_ENABLE_TORCH_COMPILE=false
# Activa xFormers memory-efficient attention si está disponible
DIFFUSERS_ENABLE_XFORMERS=false
# Offload en Diffusers (`none`, `model`, `sequential`); `none` maximiza rendimiento
DIFFUSERS_OFFLOAD_MODE=none
# Permitir TF32 en CUDA (mejor rendimiento en Ampere/Ada para inferencia)
DIFFUSERS_ALLOW_TF32=true
# Buffer de VRAM a reservar siempre libre (MB)
VRAM_BUFFER_MB=512
# Umbral de VRAM usada (%) que dispara evicción automática
VRAM_PRESSURE_THRESHOLD_PCT=90

# Máximo tamaño por parte multipart para /v1/audio/transcriptions (MB)
OPENAI_AUDIO_MAX_PART_SIZE_MB=256
# Timeout de arranque del worker Whisper (segundos); la diarización en cold-start puede tardar más
WHISPER_STARTUP_TIMEOUT_S=300

# --- Evicción de modelos ---
# Tiempo de inactividad antes de descargar modelos on_demand (segundos)
IDLE_TIMEOUT_SECONDS=300
# Frecuencia del chequeo de evicción por inactividad (segundos)
IDLE_EVICTION_CHECK_INTERVAL_SECONDS=15

# --- Usuario/GID para contenedores dev (evita ficheros root en bind mounts) ---
FRONTEND_UID=1000
FRONTEND_GID=1000

# --- Servicios de generación interactivos ---
# URLs internas Docker de cada servicio (para health checks y unload desde el backend)
HUNYUAN_BASE_URL=http://hunyuan:8080
COMFYUI_BASE_URL=http://comfyui:8188
A1111_BASE_URL=http://a1111:7860
ACESTEP_BASE_URL=http://acestep:7860
# Puerto del host en que se expone cada servicio directamente
HUNYUAN_PORT=8480
COMFYUI_PORT=8188
A1111_PORT=7860
ACESTEP_PORT=7860
# URL pública completa que usará el navegador para abrir cada servicio
# Ejemplo: https://mi-servidor.com:8480  o  https://hunyuan.mi-servidor.com
HUNYUAN_UI_URL=
COMFYUI_UI_URL=
A1111_UI_URL=
ACESTEP_UI_URL=
# GPU preferida por servicio (0=RTX3060 12GB, 1=RTX3090 24GB)
HUNYUAN_PREFERRED_GPU=1
COMFYUI_PREFERRED_GPU=1
A1111_PREFERRED_GPU=1
ACESTEP_PREFERRED_GPU=1
# Segundos de inactividad antes de liberar VRAM del servicio
HUNYUAN_IDLE_UNLOAD_SECONDS=300
COMFYUI_IDLE_UNLOAD_SECONDS=600
A1111_IDLE_UNLOAD_SECONDS=600
ACESTEP_IDLE_UNLOAD_SECONDS=1800
# Segundos de espera para que termine una generación activa antes de forzar la evicción
# 0 = evictar inmediatamente, -1 = esperar indefinidamente
HUNYUAN_GENERATION_GRACE_PERIOD_S=120
COMFYUI_GENERATION_GRACE_PERIOD_S=120
A1111_GENERATION_GRACE_PERIOD_S=120
ACESTEP_GENERATION_GRACE_PERIOD_S=180
# Umbral de utilización GPU (%) para detectar generación en servicios sin endpoint de estado
GENERATION_GPU_UTIL_THRESHOLD_PCT=50
# Nombres de contenedor Docker para detectar/gestionar cada servicio
HUNYUAN_DOCKER_CONTAINER=ocabra-hunyuan-1
COMFYUI_DOCKER_CONTAINER=ocabra-comfyui-1
A1111_DOCKER_CONTAINER=ocabra-a1111-1
ACESTEP_DOCKER_CONTAINER=ocabra-acestep-1
# Puerto del host para el portal oCabra / gateway de servicios
SERVICES_PORTAL_PORT=8485
# Puerto del host para el gateway de servicios de generación
GATEWAY_PORT=9001
# URL pública del directorio de servicios (página de acceso rápido a todos los servicios)
DIRECTORY_UI_URL=

# --- LiteLLM ---
LITELLM_BASE_URL=http://litellm:4000
LITELLM_ADMIN_KEY=
# Sincronizar modelos automáticamente con LiteLLM al cargar/descargar
LITELLM_AUTO_SYNC=false

# --- Energía ---
# Coste de la electricidad en €/kWh (para estimación de costes)
ENERGY_COST_EUR_KWH=0.15

# --- Auth ---
# OCABRA_ADMIN_USER=ocabra
# OCABRA_ADMIN_PASS=ocabra
# JWT_SECRET=   # Genera con: python -c "import secrets; print(secrets.token_hex(32))"
#               # Si está vacío se genera uno aleatorio en cada arranque (invalida sesiones)
# REQUIRE_API_KEY_OPENAI=true
# REQUIRE_API_KEY_OLLAMA=true

# --- Servidor ---
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
# Versión de la aplicación
APP_VERSION=0.1.0
